# Copy to .env and fill from official LitVM docs + ../research/LITVM.md
# Never commit real keys or secrets.

# --- LitVM watcher (required) ---
# WebSocket JSON-RPC (mlnd); use values from LitVM docs
# MLND_WS_URL=wss://REPLACE_WITH_OFFICIAL_LITVM_WS
# MLND_COURT_ADDR=0xREPLACE_GRIEVANCE_COURT
# MLND_OPERATOR_ADDR=0xYOUR_MAKER_ADDRESS
# MLND_DB_PATH=mlnd.db

# HTTP JSON-RPC for `cast` / make testnet-smoke (often different host/path than WS)
# MLND_HTTP_URL=https://REPLACE_WITH_OFFICIAL_LITVM_HTTP

# --- Auto-defend (optional; hot key) ---
# MLND_DEFEND_AUTO=0
# MLND_OPERATOR_PRIVATE_KEY=
# MLND_DEFEND_DRY_RUN=1

# --- Nostr broadcaster (optional) ---
# MLND_NOSTR_RELAYS=wss://relay.example.com
# MLND_NOSTR_NSEC=nsec1...
# MLND_LITVM_CHAIN_ID=REPLACE_DECIMAL_CHAIN_ID
# MLND_REGISTRY_ADDR=0xREPLACE_REGISTRY
# MLND_NOSTR_INTERVAL=30m
# MLND_TOR_ONION=
# MLND_TOR_PORT=
# MLND_FEE_MIN_SAT=
# MLND_FEE_MAX_SAT=

# --- coinswapd receipt bridge (optional) ---
# MLND_BRIDGE_COINSWAPD=0
# MLND_BRIDGE_RECEIPTS_DIR=/path/to/receipts
# MLND_BRIDGE_POLL_INTERVAL=2s
