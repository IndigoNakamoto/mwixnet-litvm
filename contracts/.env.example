# Copy to contracts/.env (never commit .env). Aligns with PHASE_16_PUBLIC_TESTNET.md section 0 step 2.
# PRIVATE_KEY — read by Deploy.s.sol via vm.envUint (Foundry loads .env when present).
PRIVATE_KEY=

# RPC_URL — pass to forge: forge script script/Deploy.s.sol:Deploy --rpc-url "$RPC_URL" --broadcast
# Example (Sepolia stand-in until official LitVM testnet RPC): https://rpc.sepolia.org
# LitVM testnet: use HTTP JSON-RPC from official docs (chain id is inferred from the endpoint).
RPC_URL=

# ETHERSCAN_API_KEY — for contract verification with forge script ... --verify --etherscan-api-key "$ETHERSCAN_API_KEY"
# (Sepolia uses etherscan.io keys; LitVM may document a different explorer/API when published.)

# Optional overrides for Deploy.s.sol
# MIN_STAKE=100000000000000000
# COOLDOWN_PERIOD=172800
# CHALLENGE_WINDOW=86400
# GRIEVANCE_BOND_MIN=10000000000000000
# SLASH_BPS=10000
# BOUNTY_BPS=1000
# BURN_BPS=9000
# SLASHING_WINDOW=604800
#
# After --broadcast: contracts/broadcast/Deploy.s.sol/<chainId>/run-latest.json
# Wire mlnd / CLI: from repo root  make record-litvm-deploy  (PHASE_16_PUBLIC_TESTNET.md).
#
# Broadcast from repo root (script cds to contracts/ and sources .env):  make broadcast-litvm
