# Per-box maker env template for Tier 2 / Tier 3 (LitVM chain 4441).
# Copy to deploy/tier2.maker-box.env on each mini (chmod 600) and fill in the five *_THIS_MAKER values.
# Shared across boxes: relay URL, LitVM endpoints, chain id, registry/court addresses.
#
# Used by scripts/maker-box-up.sh on that host. Not committed with secrets.

# ---- Shared (same on every maker box) ----
MLND_WS_URL=wss://liteforge.rpc.caldera.xyz/ws
MLND_HTTP_URL=https://liteforge.rpc.caldera.xyz/http
MLND_LITVM_CHAIN_ID=4441
MLND_REGISTRY_ADDR=0x01bd8c4fca29cddd354472b3f31ef243ba92ffe7
MLND_COURT_ADDR=0xc303368899eac7508cfdaaedf9b8d03f75462593

# Curated relay (see research/PHASE_3_TIER2_RELAY.md). Replace with your own URL.
MLND_NOSTR_RELAYS=ws://REPLACE_RELAY_HOST:7080/

# 30s during bring-up; bump to 30m once ads are flowing stably.
MLND_NOSTR_INTERVAL=30s

# Optional: set to true if your relay enforces NIP-42 AUTH.
# MLND_NOSTR_AUTH=false

# ---- THIS_MAKER (different on every box; fill in from your scratch key set) ----
# Registered EVM address on chain 4441 (must match the private key below; used by mlnd for receipts).
MLND_OPERATOR_ADDR=0xREPLACE_THIS_MAKER_OPERATOR

# Hot private key for this maker (0x + 64 hex). chmod 600 the file holding this.
MLND_OPERATOR_PRIVATE_KEY=REPLACE_THIS_MAKER_PRIVATE_KEY

# Nostr secret for this maker's ads (nsec1… or 64-hex). Must match the keccak256 pubkey hash
# registered via `mln-cli maker onboard` on chain 4441.
MLND_NOSTR_NSEC=REPLACE_THIS_MAKER_NSEC

# The full Tor hidden service URL that clients will dial for this maker's coinswapd JSON-RPC.
# Read from /opt/homebrew/var/lib/tor/mln-maker/hostname after `brew services start tor`.
MLND_TOR_ONION=http://REPLACE_THIS_MAKER.onion:8334

# X25519 swap pubkey (64 hex). Generate once; the public half goes into the ad.
# openssl genpkey -algorithm X25519 -outform DER | tail -c 32 | xxd -p -c 64
MLND_SWAP_X25519_PUB_HEX=REPLACE_THIS_MAKER_X25519_PUB

# ---- coinswapd-research flags ----
# Fee MWEB address (ltcmweb1…) that this maker earns into. Required by the fork even for Tier 2.
COINSWAPD_FEE_MWEB=ltcmweb1REPLACE_THIS_MAKER_FEE

# Mesh ECDH key (64 hex). Any fresh random hex works for a private 3-maker run; do not reuse
# between makers.
COINSWAPD_MESH_K=REPLACE_THIS_MAKER_MESH_K

# MWEB scan/spend secrets (64 hex each). For Tier 2 you can use throwaway keys; for Tier 3
# these must correspond to the wallet the maker actually controls.
MWEB_SCAN_SECRET=REPLACE_64_HEX
MWEB_SPEND_SECRET=REPLACE_64_HEX

# ---- Local paths (adjust per box if needed) ----
MLND_DB_PATH=$HOME/mlnd.db
MLND_FEE_MIN_SAT=1
MLND_FEE_MAX_SAT=100
COINSWAPD_LISTEN_PORT=8334
