# Copy to deploy/.env.testnet (gitignored). Never commit secrets.
# Replace placeholders from your protocol admin / official LitVM docs (see research/LITVM.md, PHASE_16_PUBLIC_TESTNET.md).
#
# After forge broadcast on LitVM testnet, auto-fill registry + court + chain id:
#   make record-litvm-deploy
# Then merge deploy/litvm-addresses.generated.env into this file (or paste MLND_* lines).
# Full sequence: PHASE_16_PUBLIC_TESTNET.md section 0.

# --- LitVM JSON-RPC (mlnd uses WebSocket; HTTP optional for cast / make testnet-smoke) ---
# Must be the same chain as MLND_LITVM_CHAIN_ID. https:// URLs are NOT a substitute for MLND_WS_URL.
MLND_WS_URL=wss://REPLACE_WITH_WS_JSON_RPC_SAME_CHAIN
# MLND_HTTP_URL=https://REPLACE_WITH_HTTP_JSON_RPC_SAME_CHAIN

MLND_LITVM_CHAIN_ID=11155111
MLND_REGISTRY_ADDR=0xREPLACE_MWIXNET_REGISTRY
MLND_COURT_ADDR=0xREPLACE_GRIEVANCE_COURT
MLND_OPERATOR_ADDR=0xREPLACE_YOUR_REGISTERED_MAKER_EVM_ADDRESS

# --- Operator hot key (testnet-only; dedicated key; minimal balance) ---
# Must derive MLND_OPERATOR_ADDR. Required for MLND_DEFEND_AUTO=1.
MLND_OPERATOR_PRIVATE_KEY=REPLACE_64_HEX_OR_0X_PREFIX

# --- Nostr maker ads (kind 31250) ---
MLND_NOSTR_NSEC=nsec1REPLACE_OR_64_CHAR_HEX
MLND_NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol
MLND_NOSTR_INTERVAL=30m

# --- Storage (matches docker-compose.testnet.yml volume mounts) ---
MLND_DB_PATH=/data/mlnd.db

# --- Automated grievance defense (optional) ---
# MLND_DEFEND_AUTO=false
# MLND_DEFEND_DRY_RUN=true

# --- Tor mix API in ad content (optional) ---
# MLND_TOR_ONION=http://youronion.onion:PORT

# --- coinswapd NDJSON bridge (optional; mount /receipts in compose) ---
# MLND_BRIDGE_COINSWAPD=0
# MLND_BRIDGE_RECEIPTS_DIR=/receipts
# MLND_BRIDGE_POLL_INTERVAL=2s
