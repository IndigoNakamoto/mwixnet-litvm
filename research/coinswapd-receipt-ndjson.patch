diff --git a/mlnreceipt/writer.go b/mlnreceipt/writer.go
new file mode 100644
index 0000000..c569999
--- /dev/null
+++ b/mlnreceipt/writer.go
@@ -0,0 +1,63 @@
+package mlnreceipt
+
+import (
+	"crypto/sha256"
+	"encoding/hex"
+	"encoding/json"
+	"fmt"
+	"os"
+	"path/filepath"
+	"strings"
+
+	"github.com/ltcmweb/ltcd/ltcutil/mweb/mw"
+	"golang.org/x/crypto/sha3"
+)
+
+// WriteForwardReceipt appends one NDJSON object line for mlnd (see mwixnet-litvm PHASE_6_BRIDGE_INTEGRATION.md).
+// peeledCommitment = sha256(33-byte ltcd compressed Pedersen commitment); forwardCiphertextHash = keccak256(postXOR).
+func WriteForwardReceipt(dir, epochID, accuser, accused string, hopIndex uint8, commit2 mw.Commitment, postXOR []byte, nextHop, sig string) error {
+	dir = strings.TrimSpace(dir)
+	if dir == "" {
+		return nil
+	}
+	epochID = strings.TrimSpace(epochID)
+	accuser = strings.TrimSpace(accuser)
+	accused = strings.TrimSpace(accused)
+	if epochID == "" || accuser == "" || accused == "" {
+		return fmt.Errorf("mln receipt: set -mln-receipt-epoch-id, -mln-receipt-accuser, and -mln-receipt-accused when -mln-receipt-dir is set")
+	}
+
+	peeled := sha256.Sum256(commit2[:])
+	fh := keccak256(postXOR)
+
+	rec := map[string]interface{}{
+		"epochId":               epochID,
+		"accuser":               accuser,
+		"accusedMaker":          accused,
+		"hopIndex":              int(hopIndex),
+		"peeledCommitment":      "0x" + hex.EncodeToString(peeled[:]),
+		"forwardCiphertextHash": "0x" + hex.EncodeToString(fh),
+		"nextHopPubkey":         nextHop,
+		"signature":             sig,
+	}
+	raw, err := json.Marshal(rec)
+	if err != nil {
+		return err
+	}
+	path := filepath.Join(dir, "mlnd-receipts.ndjson")
+	f, err := os.OpenFile(path, os.O_APPEND|os.O_CREATE|os.O_WRONLY, 0o644)
+	if err != nil {
+		return err
+	}
+	defer f.Close()
+	if _, err := f.Write(append(raw, '\n')); err != nil {
+		return err
+	}
+	return nil
+}
+
+func keccak256(b []byte) []byte {
+	h := sha3.NewLegacyKeccak256()
+	h.Write(b)
+	return h.Sum(nil)
+}
