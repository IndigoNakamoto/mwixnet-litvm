# Copy to `.env` in the repo root for `docker compose`. Never commit `.env`.
# Replace every REPLACE_* / example value from official LitVM docs + research/LITVM.md.

# ==========================================
# mlnd — LitVM connection and identity
# ==========================================

# WebSocket JSON-RPC (required for mlnd ethclient)
MLND_WS_URL=wss://REPLACE_WITH_OFFICIAL_LITVM_WS

# Decimal chain ID (Nostr ad binding + docs)
MLND_LITVM_CHAIN_ID=REPLACE_DECIMAL_CHAIN_ID

MLND_COURT_ADDR=0xREPLACE_GRIEVANCE_COURT
MLND_REGISTRY_ADDR=0xREPLACE_REGISTRY
MLND_OPERATOR_ADDR=0xREPLACE_OPERATOR_EVM_ADDRESS

# HTTP JSON-RPC for `make testnet-smoke` / cast (often different from WS URL)
# MLND_HTTP_URL=https://REPLACE_WITH_OFFICIAL_LITVM_HTTP

# ==========================================
# Automated defense (LitVM)
# ==========================================

# Truthy: 1, true, yes
MLND_DEFEND_AUTO=false
MLND_DEFEND_DRY_RUN=true

# 64 hex chars, optional 0x; must derive MLND_OPERATOR_ADDR
MLND_OPERATOR_PRIVATE_KEY=REPLACE_64_HEX_PRIVATE_KEY

# ==========================================
# Nostr maker ads (kind 31250)
# ==========================================

MLND_NOSTR_NSEC=nsec1REPLACE_OR_64_CHAR_HEX
MLND_NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol
MLND_NOSTR_INTERVAL=30m

# Tor mix API URL for ad content (optional)
# MLND_TOR_ONION=http://youronion.onion:PORT

# ==========================================
# Storage and coinswapd NDJSON bridge
# ==========================================

# Matches docker-compose volume mount ./data/mlnd:/data
MLND_DB_PATH=/data/mlnd.db

MLND_BRIDGE_COINSWAPD=1
MLND_BRIDGE_RECEIPTS_DIR=/receipts

# MLND_BRIDGE_POLL_INTERVAL=2s
